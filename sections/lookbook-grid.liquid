<div class="lookbook-grid full-width">
  {% if section.settings.heading != blank %}
    <div class="lookbook-grid__header">
      <span class="lookbook-grid__heading">{{ section.settings.heading }}</span>
    </div>
  {% endif %}

  <div class="lookbook-grid__grid">
    {% for block in section.blocks %}
      {% if block.type == 'image' %}
        <div
          class="lookbook-grid__item {{ block.settings.size }}"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.url != blank %}
            <a href="{{ block.settings.url }}" class="lookbook-grid__link">
          {% endif %}

          <div class="lookbook-grid__image-wrapper">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 1200 | image_tag:
                class: 'lookbook-grid__image',
                loading: 'lazy'
              }}
            {% else %}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'lookbook-grid__image lookbook-grid__placeholder' }}
            {% endif %}
          </div>

          {% if block.settings.caption != blank %}
            <span class="lookbook-grid__caption">{{ block.settings.caption }}</span>
          {% endif %}

          {% if block.settings.url != blank %}
            </a>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .lookbook-grid {
    padding: 0;
  }

  .lookbook-grid__header {
    padding: 32px var(--page-margin) 20px;
  }

  .lookbook-grid__heading {
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .lookbook-grid__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
  }

  .lookbook-grid__item {
    overflow: hidden;
  }

  .lookbook-grid__item--wide {
    grid-column: span 2;
  }

  .lookbook-grid__item--tall {
    grid-row: span 2;
  }

  .lookbook-grid__link {
    display: block;
    text-decoration: none;
    color: var(--color-foreground);
  }

  .lookbook-grid__image-wrapper {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background-color: #f0f0f0;
  }

  .lookbook-grid__item--wide .lookbook-grid__image-wrapper {
    aspect-ratio: 3 / 2;
  }

  .lookbook-grid__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .lookbook-grid__link:hover .lookbook-grid__image {
    transform: scale(1.03);
  }

  .lookbook-grid__placeholder {
    width: 100%;
    height: 100%;
  }

  .lookbook-grid__caption {
    display: block;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 12px var(--page-margin) 20px;
  }

  @media (max-width: 768px) {
    .lookbook-grid__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.lookbook_grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Lookbook"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "t:general.image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "t:labels.caption"
        },
        {
          "type": "url",
          "id": "url",
          "label": "t:labels.url"
        },
        {
          "type": "select",
          "id": "size",
          "label": "t:labels.size",
          "default": "lookbook-grid__item--default",
          "options": [
            { "value": "lookbook-grid__item--default", "label": "t:options.size.default" },
            { "value": "lookbook-grid__item--wide", "label": "t:options.size.wide" },
            { "value": "lookbook-grid__item--tall", "label": "t:options.size.tall" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.lookbook_grid",
      "blocks": [
        { "type": "image", "settings": { "size": "lookbook-grid__item--wide" } },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image", "settings": { "size": "lookbook-grid__item--wide" } }
      ]
    }
  ]
}
{% endschema %}
