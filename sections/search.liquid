<div class="search-page">
  <div class="search-page__header">
    <h1 class="search-page__title">{{ 'search.title' | t }}</h1>

    <form action="{{ routes.search_url }}" method="get" role="search" class="search-page__form">
      <label for="search-input" class="visually-hidden">{{ 'search.placeholder' | t }}</label>
      <input
        type="search"
        id="search-input"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ 'search.placeholder' | t | upcase }}"
        class="search-page__input"
        autofocus
      >
      <button type="submit" class="search-page__submit">{{ 'search.submit' | t }}</button>
    </form>
  </div>

  {% if search.performed %}
    {% if search.results_count == 0 %}
      <div class="search-page__empty">
        <p class="search-page__no-results">{{ 'search.no_results_html' | t: terms: search.terms }}</p>
      </div>
    {% else %}
      <p class="search-page__count">
        {{ 'search.results_for_html' | t: terms: search.terms, count: search.results_count }}
      </p>

      {% paginate search.results by 20 %}
        <div class="search-page__grid">
          {% for result in search.results %}
            <div class="search-page__card">
              <a href="{{ result.url }}" class="search-page__card-link">
                {% assign featured_image = result.featured_image | default: result.image %}
                <div class="search-page__image-wrapper">
                  {% if featured_image %}
                    <img
                      src="{{ featured_image | image_url: width: 600, height: 800, crop: 'center' }}"
                      alt="{{ featured_image.alt | escape }}"
                      loading="lazy"
                      width="600"
                      height="800"
                      class="search-page__image"
                    >
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'search-page__image search-page__placeholder' }}
                  {% endif %}
                </div>

                <div class="search-page__info">
                  <span class="search-page__result-title">{{ result.title }}</span>
                  {% if result.price %}
                    <span class="search-page__price">{{ result.price | money }}</span>
                  {% endif %}
                </div>
              </a>
            </div>
          {% endfor %}
        </div>

        {% if paginate.pages > 1 %}
          <nav class="search-page__pagination" aria-label="{{ 'search.pagination' | t }}">
            {% if paginate.previous %}
              <a href="{{ paginate.previous.url }}" class="search-page__pagination-link">
                {{ 'collection.previous' | t }}
              </a>
            {% endif %}

            <span class="search-page__pagination-current">
              {{ paginate.current_page }} / {{ paginate.pages }}
            </span>

            {% if paginate.next %}
              <a href="{{ paginate.next.url }}" class="search-page__pagination-link search-page__pagination-link--next">
                {{ 'collection.next' | t }}
              </a>
            {% endif %}
          </nav>
        {% endif %}
      {% endpaginate %}
    {% endif %}
  {% endif %}
</div>

{% stylesheet %}
  .search-page__header {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 32px 0;
  }

  .search-page__title {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .search-page__form {
    display: flex;
    gap: 0;
    max-width: 480px;
  }

  .search-page__input {
    flex: 1;
    border: none;
    border-bottom: 1px solid var(--color-foreground);
    background: none;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 10px 0;
    outline: none;
    color: var(--color-foreground);
    font-family: inherit;
    border-radius: 0;
  }

  .search-page__input::placeholder {
    color: var(--color-foreground);
    opacity: 0.5;
  }

  .search-page__submit {
    background-color: var(--color-foreground);
    color: var(--color-background);
    border: 1px solid var(--color-foreground);
    padding: 10px 24px;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    font-family: inherit;
    transition: opacity 0.2s;
  }

  .search-page__submit:hover {
    opacity: 0.85;
  }

  .search-page__empty {
    padding: 48px 0;
    text-align: center;
  }

  .search-page__no-results {
    font-size: 13px;
    opacity: 0.6;
  }

  .search-page__count {
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.5;
    padding-bottom: 16px;
  }

  .search-page__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
  }

  .search-page__card-link {
    text-decoration: none;
    color: var(--color-foreground);
  }

  .search-page__image-wrapper {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background-color: #f0f0f0;
  }

  .search-page__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .search-page__card-link:hover .search-page__image {
    transform: scale(1.03);
  }

  .search-page__placeholder {
    width: 100%;
    height: 100%;
  }

  .search-page__info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 16px 24px;
  }

  .search-page__result-title {
    font-size: 13px;
  }

  .search-page__price {
    font-size: 13px;
    font-weight: 600;
  }

  .search-page__pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 32px;
    padding: 40px 0;
  }

  .search-page__pagination-link {
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-foreground);
    opacity: 0.5;
    transition: opacity 0.2s;
  }

  .search-page__pagination-link:hover {
    opacity: 1;
  }

  .search-page__pagination-link--next {
    opacity: 1;
    font-weight: 600;
  }

  .search-page__pagination-current {
    font-size: 13px;
    letter-spacing: 0.08em;
  }

  @media (max-width: 1024px) {
    .search-page__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .search-page__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.search",
  "settings": []
}
{% endschema %}
