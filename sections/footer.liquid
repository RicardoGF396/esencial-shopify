<footer class="footer full-width">
  <div class="footer__upper">
    <div class="footer__column">
      <h3 class="footer__heading">{{ 'footer.contact_us' | t }}</h3>
      <ul class="footer__list">
        <li><a href="#" class="footer__link">{{ 'footer.whatsapp' | t }}</a></li>
        <li><a href="mailto:" class="footer__link">{{ 'footer.email' | t }}</a></li>
      </ul>
    </div>

    <div class="footer__column">
      <h3 class="footer__heading">{{ 'footer.store' | t }}</h3>
      <ul class="footer__list">
        <li><a href="#" class="footer__link">{{ 'footer.shipping' | t }}</a></li>
        <li><a href="#" class="footer__link">{{ 'footer.payments' | t }}</a></li>
        <li><a href="#" class="footer__link">{{ 'footer.returns' | t }}</a></li>
      </ul>
    </div>

    <div class="footer__column">
      <h3 class="footer__heading">{{ 'footer.join_community' | t }}</h3>
      <p class="footer__description">{{ 'footer.join_description' | t }}</p>
      {% form 'customer' %}
        <div class="footer__newsletter">
          <label for="footer-email" class="footer__label">{{ 'footer.email_placeholder' | t }}</label>
          <input
            type="email"
            id="footer-email"
            name="contact[email]"
            class="footer__input"
            required
          >
          <p class="footer__privacy">{{ 'footer.privacy_consent' | t }}</p>
          <button type="submit" class="footer__button">{{ 'footer.subscribe' | t }}</button>
        </div>
      {% endform %}
    </div>
  </div>

  <div class="footer__lower">
    <div class="footer__column">
      <p class="footer__text">{{ 'footer.shipping_country' | t }}</p>
      <p class="footer__text">{{ 'footer.language' | t }}</p>
    </div>

    <div class="footer__column">
      <ul class="footer__list">
        <li><a href="#" class="footer__link">{{ 'footer.about_us' | t }}</a></li>
        <li><a href="#" class="footer__link">{{ 'footer.travel_capsule' | t }}</a></li>
        <li><a href="#" class="footer__link">{{ 'footer.contact' | t }}</a></li>
      </ul>
    </div>

    <div class="footer__column">
      <ul class="footer__list">
        <li><a href="mailto:" class="footer__link">support@leonmoda.com</a></li>
        <li><span class="footer__text">Tel: +52 000 000 0000</span></li>
      </ul>
      <ul class="footer__list footer__list--spaced">
        <li><a href="#" class="footer__link">{{ 'footer.privacy_policy' | t }}</a></li>
        <li><a href="#" class="footer__link">{{ 'footer.terms' | t }}</a></li>
      </ul>
    </div>

    <div class="footer__column footer__column--end">
      <a href="#" class="footer__link">{{ 'footer.instagram' | t }}</a>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="footer__bottom-left">
      <span class="footer__text">{{ 'footer.powered_by' | t }} {{ shop.name }}</span>
    </div>
    <div class="footer__bottom-center">
      <span class="footer__text">Copyright &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</span>
    </div>
    <div class="footer__bottom-right">
      {% if section.settings.show_payment_icons %}
        <div class="footer__payment">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag }}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer {
    background-color: #f0f0f0;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-foreground);
    margin-top: auto;
  }

  .footer a {
    text-decoration: none;
    color: var(--color-foreground);
  }

  .footer a:hover {
    opacity: 0.7;
  }

  .footer__upper {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2rem;
    padding: 3rem 4rem;
  }

  .footer__lower {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 2rem;
    padding: 2rem 4rem 3rem;
  }

  .footer__heading {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
  }

  .footer__list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__list--spaced {
    margin-top: 1.5rem;
  }

  .footer__link {
    font-size: 0.8rem;
  }

  .footer__text {
    font-size: 0.8rem;
    line-height: 1.6;
  }

  .footer__description {
    font-size: 0.8rem;
    text-transform: none;
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }

  .footer__label {
    font-size: 0.75rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  .footer__input {
    width: 100%;
    max-width: 300px;
    padding: 0.75rem 0;
    border: none;
    border-bottom: 1px solid #ccc;
    background: transparent;
    font-size: 0.8rem;
    outline: none;
  }

  .footer__privacy {
    font-size: 0.7rem;
    text-transform: none;
    color: #888;
    margin-top: 0.5rem;
    margin-bottom: 1rem;
  }

  .footer__button {
    background-color: var(--color-foreground);
    color: var(--color-background);
    border: 1px solid var(--color-foreground);
    padding: 0.6rem 1.2rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
  }

  .footer__column--end {
    justify-self: end;
    align-self: start;
  }

  .footer__bottom {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    align-items: center;
    padding: 1.5rem 4rem;
    border-top: 1px solid #ccc;
    font-size: 0.75rem;
  }

  .footer__bottom-center {
    text-align: center;
  }

  .footer__bottom-right {
    justify-self: end;
  }

  .footer__payment {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .footer__payment svg {
    width: 2.5rem;
    height: auto;
  }

  @media (max-width: 768px) {
    .footer__upper {
      grid-template-columns: 1fr;
      padding: 2rem 1.5rem;
    }
    .footer__lower {
      grid-template-columns: 1fr 1fr;
      padding: 1.5rem;
    }
    .footer__bottom {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding: 1.5rem;
      text-align: center;
    }
    .footer__bottom-center,
    .footer__bottom-right {
      justify-self: center;
    }
    .footer__column--end {
      justify-self: start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    }
  ]
}
{% endschema %}
