{% stylesheet %}
  /* ─── Shared utilities ─────────────────────────────────────── */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .header__link {
    text-decoration: none;
    color: var(--color-foreground);
    font-size: 0.73rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    padding: 0;
    transition: opacity 0.2s;
  }

  .header__link:hover {
    opacity: 0.6;
  }

  /* ─── Header ─────────────────────────────────────────────────── */
  .shopify-section:has(> .header),
  .header-section-sticky {
    position: sticky;
    top: 0;
    z-index: 100;
    align-self: start;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .shopify-section:has(> .header[data-mega-open]),
  .header-section-sticky[data-mega-open] {
    z-index: 200;
  }

  .header {
    background-color: var(--color-background);
    border-bottom: 1px solid #e5e5e5;
    --header-height: 3rem;
  }

  .header__desktop {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 var(--page-margin);
    height: 3rem;
    gap: 1rem;
    position: relative;
    z-index: 3;
    background-color: var(--color-background);
  }

  .header__left {
    display: flex;
    gap: 1.75rem;
    align-items: center;
    height: 100%;
  }

  .header__right {
    display: flex;
    gap: 1.75rem;
    align-items: center;
    justify-self: end;
  }

  .header__nav-trigger {
    height: 100%;
    display: flex;
    align-items: center;
    position: relative;
  }

  .header__nav-trigger::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background-color: var(--color-foreground);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.25s ease;
  }

  .header__nav-trigger--active::after {
    transform: scaleX(1);
  }

  .header__center {
    justify-self: center;
  }

  .header__logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .header__logo-img {
    height: 1.5rem;
    width: auto;
  }

  .header__cart-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 1.5rem;
    height: 1.5rem;
    padding: 0 6px;
    border: 1px solid var(--color-foreground);
    text-decoration: none;
    color: var(--color-foreground);
    font-size: 0.7rem;
    flex-shrink: 0;
  }

  /* ─── Mega menu ─────────────────────────────────────────────── */
  .mega {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mega--active {
    pointer-events: auto;
    max-height: 80vh;
  }

  .mega-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.35s ease, background 0.35s ease, visibility 0s linear 0.35s;
    z-index: 50;
    pointer-events: none;
  }

  .mega-backdrop--active {
    background: rgba(0, 0, 0, 0.3);
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition: opacity 0.35s ease, background 0.35s ease, visibility 0s linear 0s;
  }

  .mega__panel {
    background: var(--color-background);
    border-bottom: 1px solid #e5e5e5;
    position: relative;
    transform: translateY(-100%);
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mega--active .mega__panel {
    transform: translateY(0);
  }


  .mega__inner {
    display: grid;
    gap: 48px;
    padding: 40px var(--page-margin) 56px;
  }

  .mega__inner--two {
    grid-template-columns: 1fr auto;
  }

  .mega__inner--three {
    grid-template-columns: 1fr auto;
  }

  .mega__inner--five {
    grid-template-columns: 1fr auto;
  }

  .mega__links {
    display: grid;
    gap: 40px;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    max-width: none;
  }

  .mega__col {
    display: flex;
    flex-direction: column;
  }

  .mega__col-heading {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-foreground);
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid #e5e5e5;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .mega__col-heading--link:hover {
    opacity: 0.6;
  }

  .mega__col-kicker {
    font-size: 0.72rem;
    color: #888;
    margin: 0 0 16px;
    letter-spacing: 0.02em;
    line-height: 1.5;
  }

  .mega__col-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .mega__col-link {
    font-size: 0.78rem;
    text-transform: none;
    letter-spacing: 0.01em;
    text-decoration: none;
    color: var(--color-foreground);
    font-weight: 400;
    transition: opacity 0.2s;
    display: inline-block;
  }

  .mega__col-link:hover {
    opacity: 0.5;
  }

  /* Featured images in mega */
  .mega__featured {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  .mega__decor {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
    height: 400px;
  }

  .mega__decor-img {
    height: 100%;
    width: auto;
    object-fit: cover;
    display: block;
    pointer-events: none;
    user-select: none;
  }

  .mega__featured-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-foreground);
    width: 200px;
  }

  .mega__featured--three .mega__featured-link {
    width: 180px;
  }

  .mega__featured-image-wrap {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background-color: #f0f0f0;
    position: relative;
  }

  .mega__featured-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .mega__featured-link:hover .mega__featured-image {
    transform: scale(1.04);
  }

  .mega__featured-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    text-align: center;
  }

  .mega__featured-placeholder span {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #999;
    border: 1px dashed #ccc;
    padding: 8px 12px;
    line-height: 1.4;
  }

  .mega__featured-caption {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 10px 0 0;
  }

  /* ─── Search drawer ─────────────────────────────────────────── */
  .search-drawer {
    position: fixed;
    top: 0;
    right: 0;
    width: min(560px, 100%);
    height: 100dvh;
    max-width: 100%;
    max-height: 100%;
    margin: 0;
    padding: 0;
    border: none;
    background: var(--color-background);
    color: var(--color-foreground);
    transform: translateX(100%);
    transition: transform 0.35s ease;
    z-index: 1000;
  }

  .search-drawer[open] {
    transform: translateX(0);
  }

  .search-drawer::backdrop {
    background: rgba(0, 0, 0, 0.25);
  }

  .search-drawer__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 0 1.5rem;
  }

  .search-drawer__form {
    flex-shrink: 0;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-foreground);
  }

  .search-drawer__form-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .search-drawer__input {
    flex: 1;
    border: none;
    background: none;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 8px 0;
    outline: none;
    color: var(--color-foreground);
    font-family: inherit;
    font-weight: 500;
    border-radius: 0;
  }

  .search-drawer__input::placeholder {
    color: var(--color-foreground);
    opacity: 0.4;
  }

  .search-drawer__close {
    background: #f0f0f0;
    border: none;
    padding: 8px 16px;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    color: var(--color-foreground);
    font-family: inherit;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }

  .search-drawer__body {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem 0 2rem;
  }

  .search-drawer__section {
    margin-bottom: 2rem;
  }

  .search-drawer__heading {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
    margin: 0 0 1rem;
    color: var(--color-foreground);
  }

  .search-drawer__tag-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .search-drawer__tag {
    font-size: 0.95rem;
    text-decoration: none;
    color: var(--color-foreground);
    transition: opacity 0.2s;
  }

  .search-drawer__tag:hover {
    opacity: 0.6;
  }

  .search-drawer__recent {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .search-drawer__recent-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-foreground);
    position: relative;
  }

  .search-drawer__recent-img-wrap {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background-color: #f0f0f0;
    margin-bottom: 8px;
  }

  .search-drawer__recent-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .search-drawer__recent-title {
    font-size: 0.78rem;
    letter-spacing: 0.02em;
    display: block;
  }

  .search-drawer__recent-price {
    font-size: 0.78rem;
    font-weight: 600;
    margin-top: 2px;
  }

  .search-drawer__empty-text {
    font-size: 0.85rem;
    color: #999;
    margin: 0;
  }

  /* Predictive search results */
  .search-drawer__results-status {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 20px;
    min-height: 14px;
  }

  .search-drawer__results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 24px 16px;
  }

  .search-drawer__result-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-decoration: none;
    color: var(--color-foreground);
  }

  .search-drawer__result-img-wrap {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #f0f0f0;
  }

  .search-drawer__result-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .search-drawer__result-card:hover .search-drawer__result-img {
    transform: scale(1.03);
  }

  .search-drawer__result-vendor {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .search-drawer__result-title {
    font-size: 0.8rem;
    line-height: 1.3;
  }

  .search-drawer__result-price {
    font-size: 0.8rem;
    font-weight: 600;
  }

  .search-drawer__result-compare {
    opacity: 0.5;
    font-weight: 400;
    margin-right: 6px;
    text-decoration: line-through;
  }

  .search-drawer__results-all {
    display: inline-block;
    margin-top: 28px;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-foreground);
    text-decoration: none;
    border-bottom: 1px solid var(--color-foreground);
    padding-bottom: 3px;
  }

  /* ─── Mobile bar ─────────────────────────────────────────────── */
  .header__mobile {
    display: none;
  }

  .header__cart-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-foreground);
    justify-self: end;
  }

  /* ─── Responsive breakpoint ─────────────────────────────────── */
  @media (max-width: 900px) {
    .header__desktop,
    .mega {
      display: none !important;
    }

    .header__mobile {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      padding: 0 var(--page-margin);
      height: 3.5rem;
    }

    .header__mobile-menu-btn {
      justify-self: start;
    }

    .header__logo--mobile {
      justify-self: center;
    }

    .header__logo-img--mobile {
      height: 1.5rem;
    }

    .search-drawer {
      width: 100%;
    }
  }

  /* ─── Mobile menu dialog ─────────────────────────────────────── */
  .mobile-menu {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    margin: 0;
    padding: 0;
    border: none;
    background: var(--color-background);
    color: var(--color-foreground);
    z-index: 1000;
  }

  .mobile-menu::backdrop {
    background: transparent;
  }

  .mobile-menu__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 0 var(--page-margin);
    overflow: hidden;
  }

  .mobile-menu__top {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 1.25rem;
    height: 3.5rem;
    flex-shrink: 0;
  }

  .mobile-menu__close-btn {
    justify-self: start;
  }

  .mobile-menu__search {
    flex-shrink: 0;
    border-bottom: 1px solid var(--color-foreground);
    padding-bottom: 0.75rem;
    margin-bottom: 1rem;
  }

  .mobile-menu__search-input {
    width: 100%;
    border: none;
    background: none;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 8px 0;
    outline: none;
    color: var(--color-foreground);
    font-family: inherit;
    font-weight: 500;
    border-radius: 0;
  }

  .mobile-menu__search-input::placeholder {
    color: var(--color-foreground);
    opacity: 0.4;
  }

  .mobile-menu__nav {
    position: relative;
    flex: 1;
    overflow: hidden;
  }

  .mobile-menu__panel {
    position: absolute;
    inset: 0;
    overflow-y: auto;
    padding-top: 0.5rem;
    transform: translateX(100%);
    transition: transform 0.3s ease;
  }

  .mobile-menu__panel--active {
    transform: translateX(0);
  }

  .mobile-menu__panel--exit-left {
    transform: translateX(-100%);
  }

  .mobile-menu__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .mobile-menu__link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 14px 0;
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    color: var(--color-foreground);
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    text-align: left;
  }

  .mobile-menu__link--sub {
    font-size: 0.92rem;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0.01em;
    padding: 10px 0;
  }

  .mobile-menu__group {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #999;
    margin: 24px 0 4px;
    font-weight: 500;
    padding-bottom: 8px;
    border-bottom: 1px solid #eee;
  }

  .mobile-menu__group:first-of-type {
    margin-top: 12px;
  }

  .mobile-menu__chevron {
    font-size: 1.2rem;
    color: #999;
  }

  .mobile-menu__back {
    display: block;
    padding: 0.5rem 0 1rem;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: #666;
    background: none;
    border: none;
    border-bottom: 1px solid #eee;
    cursor: pointer;
    font-family: inherit;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    text-align: left;
    width: 100%;
  }

  .mobile-menu__footer {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem 0;
    flex-shrink: 0;
    margin-top: auto;
  }

  .mobile-menu__footer-item {
    font-size: 0.85rem;
    text-decoration: none;
    color: var(--color-foreground);
  }
{% endstylesheet %}

<script>
  (function () {
    var header = document.querySelector('[data-header]');
    if (!header) return;

    /* ─── Mega menus ─── */
    var triggers = header.querySelectorAll('[data-mega-trigger]');
    var megas = header.querySelectorAll('[data-mega]');
    var backdrop = document.querySelector('.mega-backdrop');
    if (backdrop && backdrop.parentElement !== document.body) {
      document.body.appendChild(backdrop);
    }
    var headerSection = header.closest('.shopify-section') || header.parentElement;
    if (headerSection) headerSection.classList.add('header-section-sticky');
    var closeTimeout = null;
    var activeMega = null;

    function updateTopbarOffset() {
      if (!headerSection || !header.hasAttribute('data-mega-open')) return;
      if (!window.matchMedia('(min-width: 901px)').matches) return;
      var topbar = document.querySelector('.topbar');
      if (!topbar) return;
      var offset = Math.max(0, topbar.getBoundingClientRect().bottom);
      headerSection.style.transform = offset > 0 ? 'translateY(-' + offset + 'px)' : '';
    }
    window.addEventListener('scroll', updateTopbarOffset, { passive: true });

    function openMega(id) {
      clearTimeout(closeTimeout);
      megas.forEach(function (m) {
        var match = m.getAttribute('data-mega') === id;
        m.classList.toggle('mega--active', match);
        m.setAttribute('aria-hidden', match ? 'false' : 'true');
        if (match) activeMega = m;
      });
      triggers.forEach(function (t) {
        var match = t.getAttribute('data-mega-trigger') === id;
        t.classList.toggle('header__nav-trigger--active', match);
        t.setAttribute('aria-expanded', match ? 'true' : 'false');
      });
      header.setAttribute('data-mega-open', '');
      if (headerSection) headerSection.setAttribute('data-mega-open', '');
      if (backdrop) backdrop.classList.add('mega-backdrop--active');
      updateTopbarOffset();
    }

    function closeAllMegas(delay) {
      clearTimeout(closeTimeout);
      closeTimeout = setTimeout(function () {
        megas.forEach(function (m) {
          m.classList.remove('mega--active');
          m.setAttribute('aria-hidden', 'true');
        });
        triggers.forEach(function (t) {
          t.classList.remove('header__nav-trigger--active');
          t.setAttribute('aria-expanded', 'false');
        });
        activeMega = null;
        header.removeAttribute('data-mega-open');
        header.style.transform = '';
        if (headerSection) {
          headerSection.removeAttribute('data-mega-open');
          headerSection.style.transform = '';
        }
        if (backdrop) backdrop.classList.remove('mega-backdrop--active');
      }, delay || 220);
    }

    triggers.forEach(function (trigger) {
      trigger.addEventListener('click', function (e) {
        e.stopPropagation();
        var id = trigger.getAttribute('data-mega-trigger');
        var target = header.querySelector('[data-mega="' + id + '"]');
        if (target && target.classList.contains('mega--active')) closeAllMegas(0);
        else openMega(id);
      });
    });

    document.querySelectorAll('[data-mega-overlay]').forEach(function (overlay) {
      overlay.addEventListener('click', function () { closeAllMegas(0); });
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && activeMega) closeAllMegas(0);
    });

    /* ─── Search drawer ─── */
    var searchDrawer = document.querySelector('[data-search-drawer]');
    var searchOpen = header.querySelector('[data-search-open]');
    var searchClose = searchDrawer && searchDrawer.querySelector('[data-search-close]');
    var searchInput = searchDrawer && searchDrawer.querySelector('[data-search-input]');

    if (searchOpen && searchDrawer) {
      searchOpen.addEventListener('click', function () {
        searchDrawer.showModal();
        renderRecentlyViewed();
        setTimeout(function () { searchInput && searchInput.focus(); }, 100);
      });
    }
    if (searchClose && searchDrawer) {
      searchClose.addEventListener('click', function () { searchDrawer.close(); });
    }
    if (searchDrawer) {
      searchDrawer.addEventListener('click', function (e) {
        if (e.target === searchDrawer) searchDrawer.close();
      });
    }

    /* ─── Predictive search ─── */
    if (searchDrawer && searchInput) {
      var defaultPane = searchDrawer.querySelector('[data-search-default]');
      var resultsPane = searchDrawer.querySelector('[data-search-results]');
      var resultsGrid = searchDrawer.querySelector('[data-search-results-grid]');
      var resultsStatus = searchDrawer.querySelector('[data-search-status]');
      var resultsAll = searchDrawer.querySelector('[data-search-all]');
      var resultsAllQuery = searchDrawer.querySelector('[data-search-all-query]');
      var searchTimer = null;
      var searchAbort = null;

      function formatMoneySearch(cents) {
        return '$ ' + (cents / 100).toFixed(2);
      }

      function showDefault() {
        if (defaultPane) defaultPane.hidden = false;
        if (resultsPane) resultsPane.hidden = true;
      }

      function showResults() {
        if (defaultPane) defaultPane.hidden = true;
        if (resultsPane) resultsPane.hidden = false;
      }

      function renderPredictive(query, products) {
        if (!resultsGrid) return;
        if (products.length === 0) {
          resultsGrid.innerHTML = '';
          resultsStatus.textContent = 'No results for "' + query + '"';
          resultsAll.hidden = true;
          return;
        }
        resultsStatus.textContent = products.length + (products.length === 1 ? ' result' : ' results');
        resultsGrid.innerHTML = products.map(function (p) {
          var img = p.featured_image
            ? '<img src="' + p.featured_image.url + '" alt="' + (p.featured_image.alt || '') + '" loading="lazy" class="search-drawer__result-img">'
            : '';
          var vendor = p.vendor ? '<span class="search-drawer__result-vendor">' + p.vendor + '</span>' : '';
          var compare = (p.compare_at_price_min && p.compare_at_price_min > p.price_min)
            ? '<s class="search-drawer__result-compare">' + formatMoneySearch(p.compare_at_price_min) + '</s>'
            : '';
          return (
            '<a href="' + p.url + '" class="search-drawer__result-card">' +
              '<div class="search-drawer__result-img-wrap">' + img + '</div>' +
              vendor +
              '<span class="search-drawer__result-title">' + p.title + '</span>' +
              '<span class="search-drawer__result-price">' + compare + formatMoneySearch(p.price_min) + '</span>' +
            '</a>'
          );
        }).join('');
        resultsAll.href = '/search?q=' + encodeURIComponent(query);
        resultsAllQuery.textContent = query;
        resultsAll.hidden = false;
      }

      function runPredictive(query) {
        if (searchAbort) searchAbort.abort();
        searchAbort = new AbortController();
        resultsStatus.textContent = 'Searching…';
        showResults();
        var url = '/search/suggest.json?q=' + encodeURIComponent(query)
          + '&resources[type]=product&resources[limit]=8&resources[options][unavailable_products]=last';
        fetch(url, { signal: searchAbort.signal })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            var products = (data.resources && data.resources.results && data.resources.results.products) || [];
            renderPredictive(query, products);
          })
          .catch(function (err) {
            if (err.name !== 'AbortError') {
              resultsStatus.textContent = 'Search unavailable';
            }
          });
      }

      searchInput.addEventListener('input', function () {
        var query = searchInput.value.trim();
        clearTimeout(searchTimer);
        if (query.length < 2) {
          if (searchAbort) searchAbort.abort();
          showDefault();
          return;
        }
        searchTimer = setTimeout(function () { runPredictive(query); }, 200);
      });

      searchDrawer.addEventListener('close', function () {
        searchInput.value = '';
        showDefault();
      });
    }

    /* ─── Recently viewed (localStorage) ─── */
    var STORAGE_KEY = 'leon_recently_viewed';
    var MAX_ITEMS = 4;

    function getRecent() {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); }
      catch (e) { return []; }
    }

    function setRecent(items) {
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(items)); }
      catch (e) { /* storage full or disabled */ }
    }

    function trackProductView() {
      var match = window.location.pathname.match(/^\/products\/([^\/\?]+)/);
      if (!match) return;
      var handle = match[1];

      fetch('/products/' + handle + '.js', { credentials: 'same-origin' })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (product) {
          if (!product) return;
          var items = getRecent().filter(function (i) { return i.handle !== handle; });
          items.unshift({
            handle: handle,
            url: product.url,
            title: product.title,
            price: product.price,
            image: product.featured_image || (product.images && product.images[0]) || null
          });
          setRecent(items.slice(0, MAX_ITEMS));
        })
        .catch(function () {});
    }

    function formatMoney(cents) {
      var amount = (cents / 100).toFixed(2);
      var currency = (window.Shopify && Shopify.currency && Shopify.currency.active) || '';
      return amount + (currency ? ' ' + currency : '');
    }

    function renderRecentlyViewed() {
      if (!searchDrawer) return;
      var recentSection = searchDrawer.querySelector('[data-recent-section]');
      var emptySection = searchDrawer.querySelector('[data-empty-section]');
      var container = searchDrawer.querySelector('[data-recent-products]');
      if (!recentSection || !container) return;

      var items = getRecent();
      if (!items.length) {
        recentSection.hidden = true;
        if (emptySection) emptySection.hidden = false;
        return;
      }

      recentSection.hidden = false;
      if (emptySection) emptySection.hidden = true;

      container.innerHTML = items.map(function (item) {
        var img = item.image
          ? '<img src="' + item.image + '" alt="" loading="lazy" class="search-drawer__recent-img">'
          : '';
        return (
          '<a href="' + item.url + '" class="search-drawer__recent-card">' +
            '<div class="search-drawer__recent-img-wrap">' + img + '</div>' +
            '<span class="search-drawer__recent-title">' + item.title + '</span>' +
            '<span class="search-drawer__recent-price">' + formatMoney(item.price) + '</span>' +
          '</a>'
        );
      }).join('');
    }

    trackProductView();

    /* ─── Mobile menu ─── */
    var dialog = document.querySelector('[data-mobile-menu]');
    if (!dialog) return;
    var openBtn = header.querySelector('[data-mobile-open]');
    var closeBtn = dialog.querySelector('[data-mobile-close]');
    var panels = dialog.querySelectorAll('[data-panel]');
    var panelHistory = ['root'];

    function resetPanels() {
      panels.forEach(function (p) {
        p.classList.remove('mobile-menu__panel--active', 'mobile-menu__panel--exit-left');
      });
      var root = dialog.querySelector('[data-panel="root"]');
      if (root) root.classList.add('mobile-menu__panel--active');
      panelHistory = ['root'];
    }

    if (openBtn) openBtn.addEventListener('click', function () { resetPanels(); dialog.showModal(); });
    if (closeBtn) closeBtn.addEventListener('click', function () { dialog.close(); });
    dialog.addEventListener('click', function (e) { if (e.target === dialog) dialog.close(); });

    dialog.querySelectorAll('[data-go-to]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var targetId = btn.getAttribute('data-go-to');
        var current = dialog.querySelector('.mobile-menu__panel--active');
        var target = dialog.querySelector('[data-panel="' + targetId + '"]');
        if (!current || !target) return;
        current.classList.remove('mobile-menu__panel--active');
        current.classList.add('mobile-menu__panel--exit-left');
        target.classList.add('mobile-menu__panel--active');
        panelHistory.push(targetId);
      });
    });

    dialog.querySelectorAll('[data-go-back]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (panelHistory.length <= 1) return;
        var currentId = panelHistory.pop();
        var prevId = panelHistory[panelHistory.length - 1];
        var current = dialog.querySelector('[data-panel="' + currentId + '"]');
        var prev = dialog.querySelector('[data-panel="' + prevId + '"]');
        if (!current || !prev) return;
        current.classList.remove('mobile-menu__panel--active');
        prev.classList.remove('mobile-menu__panel--exit-left');
        prev.classList.add('mobile-menu__panel--active');
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "paragraph",
      "content": "Navbar structure is hardcoded to match imported collections. Use blocks below to set featured images for the mega menus."
    }
  ],
  "blocks": [
    {
      "type": "featured_image",
      "name": "Mega menu featured image",
      "settings": [
        {
          "type": "select",
          "id": "slot",
          "label": "Position",
          "default": "new-products-1",
          "options": [
            { "value": "new-products-1", "label": "New Products — left image" },
            { "value": "new-products-2", "label": "New Products — right image" },
            { "value": "shop-1", "label": "Shop — image 1 (Clothing)" },
            { "value": "shop-2", "label": "Shop — image 2 (Outerwear)" },
            { "value": "shop-3", "label": "Shop — image 3 (Accessories)" }
          ]
        },
        {
          "type": "image_picker",
          "id": "featured_image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Or external image URL"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header",
      "blocks": [
        { "type": "featured_image", "settings": { "slot": "new-products-1" } },
        { "type": "featured_image", "settings": { "slot": "new-products-2" } },
        { "type": "featured_image", "settings": { "slot": "shop-1" } },
        { "type": "featured_image", "settings": { "slot": "shop-2" } },
        { "type": "featured_image", "settings": { "slot": "shop-3" } }
      ]
    }
  ]
}
{% endschema %}
