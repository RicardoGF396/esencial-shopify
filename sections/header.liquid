{%- comment -%}
  ───────────────────────────────────────────────────────────────
  HEADER — León Moda
  Navbar hardcoded to match imported collections from 8pm CSV.
  Structure:
    - NEW PRODUCTS (mega: Travel Capsule | Main Collections)
    - SHOP          (mega: Clothing | Outerwear | Accessories)
    - ARCHIVE       (direct link)
    - SEARCH drawer (popular + recently viewed)
  ───────────────────────────────────────────────────────────────
{%- endcomment -%}

{%- liquid
  assign mega_np_1 = nil
  assign mega_np_2 = nil
  assign mega_shop_1 = nil
  assign mega_shop_2 = nil
  assign mega_shop_3 = nil
  for block in section.blocks
    if block.type == 'featured_image'
      case block.settings.slot
        when 'new-products-1'
          assign mega_np_1 = block
        when 'new-products-2'
          assign mega_np_2 = block
        when 'shop-1'
          assign mega_shop_1 = block
        when 'shop-2'
          assign mega_shop_2 = block
        when 'shop-3'
          assign mega_shop_3 = block
      endcase
    endif
  endfor
-%}

<header class="header full-width" data-header>
  {%- comment -%} ─── Desktop bar ─── {%- endcomment -%}
  <div class="header__desktop">
    <nav class="header__left" aria-label="Main navigation">
      <button
        class="header__link header__nav-trigger"
        data-mega-trigger="new-products"
        aria-expanded="false"
        aria-controls="mega-new-products"
      >
        New Products
      </button>
      <a href="/collections/all" class="header__link">Shop</a>
      <a href="/collections/archive" class="header__link">Archive</a>
    </nav>

    <div class="header__center">
      <a href="{{ routes.root_url }}" class="header__logo" aria-label="{{ shop.name }}">
        <img src="{{ 'logo.svg' | asset_url }}" alt="{{ shop.name }}" class="header__logo-img">
      </a>
    </div>

    <div class="header__right">
      <button class="header__link header__search-trigger" data-search-open aria-label="Open search">
        Search
      </button>
      <a href="{{ routes.account_url }}" class="header__link">Account</a>
      <a href="/pages/wishlist" class="header__link">Wishlist</a>
      <a href="{{ routes.cart_url }}" class="header__cart-badge" aria-label="Cart with {{ cart.item_count }} items">
        {{ cart.item_count }}
      </a>
    </div>
  </div>

  {%- comment -%} ─── Mega: NEW PRODUCTS ─── {%- endcomment -%}
  <div class="mega" id="mega-new-products" data-mega="new-products" aria-hidden="true">
    <div class="mega__panel">
      <div class="mega__inner mega__inner--five">
        <div class="mega__links">
          <div class="mega__col">
            <a href="/collections/travel-capsule" class="mega__col-heading mega__col-heading--link">
              Travel Capsule
            </a>
            <p class="mega__col-kicker">The pieces that travel with you.</p>
            <ul class="mega__col-list">
              <li><a href="/collections/travel-capsule" class="mega__col-link">Shop All Travel</a></li>
              <li><a href="/collections/travel-capsule" class="mega__col-link">Travel SS26</a></li>
            </ul>
          </div>

          <div class="mega__col">
            <a href="/collections/main-ss26" class="mega__col-heading mega__col-heading--link">
              Main Collections
            </a>
            <p class="mega__col-kicker">The season's defining silhouettes.</p>
            <ul class="mega__col-list">
              <li><a href="/collections/new-in" class="mega__col-link">New In</a></li>
              <li><a href="/collections/main-ss26" class="mega__col-link">Main SS26</a></li>
              <li><a href="/collections/archive" class="mega__col-link">Archive Sale</a></li>
            </ul>
          </div>

          <div class="mega__col">
            <span class="mega__col-heading">Clothing</span>
            <ul class="mega__col-list">
              <li><a href="/collections/abiti" class="mega__col-link">Dresses</a></li>
              <li><a href="/collections/bluse" class="mega__col-link">Blouses</a></li>
              <li><a href="/collections/camicie" class="mega__col-link">Shirts</a></li>
              <li><a href="/collections/t-shirts" class="mega__col-link">T-shirts</a></li>
              <li><a href="/collections/top" class="mega__col-link">Tops</a></li>
              <li><a href="/collections/maglie" class="mega__col-link">Knitwear</a></li>
              <li><a href="/collections/gonne" class="mega__col-link">Skirts</a></li>
              <li><a href="/collections/pantaloni" class="mega__col-link">Pants</a></li>
              <li><a href="/collections/shorts" class="mega__col-link">Shorts</a></li>
              <li><a href="/collections/tute" class="mega__col-link">Jumpsuits</a></li>
            </ul>
          </div>

          <div class="mega__col">
            <span class="mega__col-heading">Outerwear</span>
            <ul class="mega__col-list">
              <li><a href="/collections/capispalla" class="mega__col-link">All Outerwear</a></li>
              <li><a href="/collections/cappotti" class="mega__col-link">Coats</a></li>
              <li><a href="/collections/giacche" class="mega__col-link">Jackets</a></li>
              <li><a href="/collections/giubbotti" class="mega__col-link">Bombers</a></li>
              <li><a href="/collections/cardigans" class="mega__col-link">Cardigans</a></li>
              <li><a href="/collections/gilet" class="mega__col-link">Vests</a></li>
              <li><a href="/collections/felpe" class="mega__col-link">Sweatshirts</a></li>
            </ul>
          </div>

          <div class="mega__col">
            <span class="mega__col-heading">Accessories</span>
            <ul class="mega__col-list">
              <li><a href="/collections/accessori-vari" class="mega__col-link">All Accessories</a></li>
            </ul>
          </div>
        </div>

        <div class="mega__featured">
          {%- render 'mega-decor' -%}
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ─── Mobile bar ─── {%- endcomment -%}
  <div class="header__mobile">
    <button class="header__link header__mobile-menu-btn" data-mobile-open aria-label="Open menu">
      Menu
    </button>
    <a href="{{ routes.root_url }}" class="header__logo header__logo--mobile" aria-label="{{ shop.name }}">
      <img src="{{ 'logo.svg' | asset_url }}" alt="{{ shop.name }}" class="header__logo-img header__logo-img--mobile">
    </a>
    <a href="{{ routes.cart_url }}" class="header__cart-link" aria-label="Cart with {{ cart.item_count }} items">
      <span class="header__cart-badge">{{ cart.item_count }}</span>
    </a>
  </div>
</header>

{%- comment -%} ─── Global mega overlay (outside header to escape transform containing block) ─── {%- endcomment -%}
<div class="mega-backdrop" data-mega-overlay aria-hidden="true"></div>

{%- comment -%} ─── Search drawer ─── {%- endcomment -%}
<dialog class="search-drawer" scroll-lock data-search-drawer aria-label="Search">
  <div class="search-drawer__inner">
    <form action="{{ routes.search_url }}" method="get" class="search-drawer__form" role="search">
      <div class="search-drawer__form-row">
        <label for="search-drawer-input" class="visually-hidden">Search</label>
        <input
          type="search"
          id="search-drawer-input"
          name="q"
          placeholder="Search"
          class="search-drawer__input"
          autocomplete="off"
          data-search-input
        >
        <button type="button" class="search-drawer__close" data-search-close aria-label="Close search">
          Close <span aria-hidden="true">×</span>
        </button>
      </div>
    </form>

    <div class="search-drawer__body">
      <div class="search-drawer__default" data-search-default>
        <section class="search-drawer__section">
          <h3 class="search-drawer__heading">Popular Searches:</h3>
          <ul class="search-drawer__tag-list">
            <li><a href="{{ routes.search_url }}?q=dress" class="search-drawer__tag">Dresses</a></li>
            <li><a href="{{ routes.search_url }}?q=jacket" class="search-drawer__tag">Jackets</a></li>
            <li><a href="{{ routes.search_url }}?q=shirt" class="search-drawer__tag">Shirts</a></li>
            <li><a href="{{ routes.search_url }}?q=pants" class="search-drawer__tag">Pants</a></li>
            <li><a href="{{ routes.search_url }}?q=travel" class="search-drawer__tag">Travel</a></li>
            <li><a href="{{ routes.search_url }}?q=new+in" class="search-drawer__tag">New In</a></li>
          </ul>
        </section>

        <section class="search-drawer__section" data-recent-section hidden>
          <h3 class="search-drawer__heading">Recently Viewed</h3>
          <div class="search-drawer__recent" data-recent-products></div>
        </section>

        <section class="search-drawer__section search-drawer__section--empty" data-empty-section>
          <p class="search-drawer__empty-text">
            Start browsing to see recently viewed items here.
          </p>
        </section>
      </div>

      <div class="search-drawer__results" data-search-results hidden>
        <div class="search-drawer__results-status" data-search-status aria-live="polite"></div>
        <div class="search-drawer__results-grid" data-search-results-grid></div>
        <a href="#" class="search-drawer__results-all" data-search-all hidden>
          See all results for "<span data-search-all-query></span>"
        </a>
      </div>
    </div>
  </div>
</dialog>

