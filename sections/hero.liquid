<div
  class="hero full-width {{ section.settings.section_height }}"
  style="--hero-bg: {{ section.settings.background_color }}"
>
  {% if section.settings.background_image != blank %}
    <img
      src="{{ section.settings.background_image }}"
      alt=""
      class="hero__background"
    >
  {% endif %}
  <div class="hero__overlay" aria-hidden="true"></div>
  <div class="hero__content">
    {% content_for 'blocks' %}
    <div class="hero__copy">
      <p class="hero__eyebrow">New Season · SS26</p>
      <h2 class="hero__headline">Dress the moment.<br>Discover the collection.</h2>
      <p class="hero__sub">Curated pieces designed for the everyday, styled for the unforgettable.</p>
      <a href="/collections/all" class="hero__cta">
        Shop All
        <span class="hero__cta-arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</div>

{% stylesheet %}
  .hero {
    position: relative;
    overflow: hidden;
    width: 100%;
    background-color: var(--hero-bg);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero__background {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .hero--full {
    min-height: 85dvh;
  }
  .hero--large {
    min-height: 80vh;
  }
  .hero--medium {
    min-height: 60vh;
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0.35) 65%,
      rgba(0, 0, 0, 0.5) 100%
    );
    pointer-events: none;
  }
  .hero__content {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: var(--content-grid);
    width: 100%;
    align-self: end;
    padding-bottom: 72px;
  }
  .hero__content > * {
    grid-column: 2;
  }
  .hero__copy {
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 660px;
    color: #fff;
    animation: hero-rise 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
    margin: 0 16px;
  }
  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero__eyebrow {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin: 0;
    opacity: 0.85;
  }
  .hero__headline {
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .hero__sub {
    font-size: 16px;
    line-height: 1.6;
    max-width: 440px;
    opacity: 0.85;
    margin: 0;
  }
  .hero__cta {
    margin-top: 12px;
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: #fff;
    color: #000;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 999px;
    transition: transform 0.25s ease, background 0.25s ease, color 0.25s ease;
  }
  .hero__cta:hover {
    background: #000;
    color: #fff;
    transform: translateY(-2px);
  }
  .hero__cta-arrow {
    display: inline-block;
    transition: transform 0.25s ease;
  }
  .hero__cta:hover .hero__cta-arrow {
    transform: translateX(4px);
  }
  @media (max-width: 600px) {
    .hero__content { padding-bottom: 48px; }
    .hero__copy { gap: 10px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.hero",
  "blocks": [{ "type": "@theme" }],
  "settings": [
    {
      "type": "text",
      "id": "background_image",
      "label": "t:labels.background_image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#e5e5e5"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "t:labels.section_height",
      "default": "hero--full",
      "options": [
        { "value": "hero--full", "label": "t:options.section_height.full" },
        { "value": "hero--large", "label": "t:options.section_height.large" },
        { "value": "hero--medium", "label": "t:options.section_height.medium" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.hero"
    }
  ]
}
{% endschema %}
