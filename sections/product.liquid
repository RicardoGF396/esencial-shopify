{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign size_option_index = -1 -%}
{%- for option in product.options_with_values -%}
  {%- assign name_down = option.name | downcase -%}
  {%- if name_down contains 'size' or name_down contains 'talla' -%}
    {%- assign size_option_index = forloop.index0 -%}
  {%- endif -%}
{%- endfor -%}

<section class="product">
  <div class="product__main-wrapper">
    <div class="product__content">
      <div class="product__content-wrapper">

        {%- comment -%} ── LEFT COLUMN — GALLERY ── {%- endcomment -%}
        <div class="product__content-main-image">
          <div class="product__content-progress-bars" aria-hidden="true">
            {%- for image in product.images -%}
              <div class="product__content-progress-bar" data-progress-bar="{{ forloop.index0 }}"></div>
            {%- endfor -%}
          </div>

          <div class="product__content-images-container" data-gallery>
            {%- if product.images.size == 0 -%}
              <div class="product__content-image-item">
                {{ 'product-1' | placeholder_svg_tag: 'product__content-image product__placeholder' }}
              </div>
            {%- else -%}
              {%- for image in product.images -%}
                <div class="product__content-image-item" data-image-index="{{ forloop.index0 }}">
                  <img
                    src="{{ image | image_url: width: 1200 }}"
                    alt="{{ image.alt | escape }}"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    class="product__content-image"
                    width="1200"
                    height="1600"
                  >
                </div>
              {%- endfor -%}
            {%- endif -%}
          </div>

          {%- if product.images.size > 1 -%}
            <div class="product__gallery-dots" aria-hidden="true">
              {%- for image in product.images -%}
                <span class="product__gallery-dot{% if forloop.first %} is-active{% endif %}" data-dot="{{ forloop.index0 }}"></span>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} ── RIGHT COLUMN — INFO (sticky) ── {%- endcomment -%}
        <div class="product__content-main-text">
          <div class="product__info-container">

            <button class="product__wishlist-button" aria-label="Add to wishlist" type="button" data-wishlist>
              <svg width="14" height="18" viewBox="0 0 14 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 1h12v16l-6-4-6 4V1z" stroke="currentColor" stroke-width="1" fill="none"/>
              </svg>
            </button>

            <div class="product__details">
              <nav class="product__breadcrumbs desktop-only" aria-label="Breadcrumb">
                {%- if product.type != blank -%}
                  <a href="/collections/{{ product.type | handleize }}" class="product__back-link">{{ product.type | upcase }}</a>
                  <span class="product__breadcrumb-sep">»</span>
                {%- endif -%}
                <a href="{{ collection.url | default: '/collections/all' }}" class="product__back-link">{{ collection.title | default: 'CLOTHES' | upcase }}</a>
              </nav>

              <h1 class="product__title">
                {%- if product.vendor != blank -%}
                  <span class="product__vendor">{{ product.vendor }}</span>
                {%- endif -%}
                {{ product.title }}
              </h1>

              {%- if product.description != blank -%}
                <div class="product__description">{{ product.description | strip_html | truncate: 180 }}</div>
              {%- endif -%}

              <div class="product__price-container">
                <h2 class="product__price">{{ current_variant.price | money_without_trailing_zeros }}</h2>
                {%- if current_variant.compare_at_price > current_variant.price -%}
                  <p class="product__omnibus">Lowest price in the previous 30 days: {{ current_variant.compare_at_price | money }}</p>
                {%- else -%}
                  <p class="product__omnibus">Lowest price in the previous 30 days: {{ current_variant.price | money }}</p>
                {%- endif -%}
                <p class="product__klarna">
                  Pay in 3 installments from <strong>{{ current_variant.price | divided_by: 3 | money }}</strong> interest-free with <span class="product__klarna-logo">Klarna.</span>
                </p>
              </div>
            </div>

            {%- comment -%} ── COLOR SELECTOR (linked products by option or product metafield) ── {%- endcomment -%}
            {%- if product.metafields.custom.color_variants.value != blank -%}
              <div class="product__colors">
                <p class="product__colors-title">Select Color:</p>
                <div class="product__colors-list">
                  {%- for linked in product.metafields.custom.color_variants.value -%}
                    <a href="{{ linked.url }}" class="product__color-item{% if linked.id == product.id %} product__color-item--active{% endif %}" aria-label="{{ linked.title }}">
                      {%- if linked.featured_image -%}
                        <img src="{{ linked.featured_image | image_url: width: 120 }}" alt="{{ linked.title | escape }}" width="60" height="80">
                      {%- endif -%}
                    </a>
                  {%- endfor -%}
                </div>
              </div>
            {%- else -%}
              <div class="product__colors">
                <p class="product__colors-title">Select Color:</p>
                <div class="product__colors-list">
                  <a href="{{ product.url }}" class="product__color-item product__color-item--active" aria-label="{{ product.title }}">
                    {%- if product.featured_image -%}
                      <img src="{{ product.featured_image | image_url: width: 120 }}" alt="{{ product.title | escape }}" width="60" height="80">
                    {%- endif -%}
                  </a>
                </div>
              </div>
            {%- endif -%}

            {%- comment -%} ── SIZE + ADD TO CART ── {%- endcomment -%}
            {% form 'product', product, class: 'product__form' %}
              <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>

              {%- unless product.has_only_default_variant -%}
                {%- for option in product.options_with_values -%}
                  {%- assign name_down = option.name | downcase -%}
                  {%- if name_down contains 'size' or name_down contains 'talla' -%}
                    <div class="product__size-selector">
                      <p class="product__size-title">Select Size</p>
                      <div class="product__sizes" role="radiogroup" aria-label="{{ option.name }}">
                        {%- for value in option.values -%}
                          {%- assign variant_for_value = nil -%}
                          {%- for v in product.variants -%}
                            {%- assign opt_key = 'option' | append: forloop.parentloop.parentloop.index -%}
                            {%- if v[opt_key] == value -%}
                              {%- assign variant_for_value = v -%}
                              {%- break -%}
                            {%- endif -%}
                          {%- endfor -%}
                          {%- assign is_available = false -%}
                          {%- if variant_for_value and variant_for_value.available -%}{%- assign is_available = true -%}{%- endif -%}
                          {%- assign is_selected = false -%}
                          {%- assign current_opt_key = 'option' | append: forloop.parentloop.index -%}
                          {%- if current_variant[current_opt_key] == value -%}{%- assign is_selected = true -%}{%- endif -%}

                          <button type="button"
                            class="product__size-option{% unless is_available %} disabled{% endunless %}{% if is_selected %} selected{% endif %}"
                            data-option-index="{{ forloop.parentloop.index0 }}"
                            data-option-value="{{ value | escape }}"
                            {% unless is_available %}disabled aria-disabled="true"{% endunless %}>
                            {{ value }}
                          </button>
                        {%- endfor -%}
                      </div>
                    </div>
                  {%- endif -%}
                {%- endfor -%}

                <select name="id" class="product__variant-select visually-hidden" aria-hidden="true" tabindex="-1">
                  {%- for variant in product.variants -%}
                    <option value="{{ variant.id }}"
                      {% if variant == current_variant %}selected{% endif %}
                      {% unless variant.available %}disabled{% endunless %}
                      data-options="{{ variant.options | join: ' / ' }}">
                      {{ variant.title }}
                    </option>
                  {%- endfor -%}
                </select>
              {%- endunless -%}

              <button type="button" class="product__button button button--primary" data-add-to-cart {% unless current_variant.available %}disabled{% endunless %}>
                <span class="product__button-label">{% if current_variant.available %}Add to Cart{% else %}Sold Out{% endif %}</span>
                <span class="product__button-price">{{ current_variant.price | money_without_trailing_zeros }}</span>
              </button>
            {% endform %}

            <div class="product__delivery-info">
              <p>
                <span>Expected Delivery</span>
                <span data-delivery-window>—</span>
              </p>
            </div>

            {%- if product.metafields.custom.made_in != blank -%}
              <span class="product-card__label product-card__label--made-in">Made in {{ product.metafields.custom.made_in }}</span>
            {%- else -%}
              <span class="product-card__label product-card__label--made-in">Made in Italy</span>
            {%- endif -%}

            {%- if product.metafields.custom.model_info != blank -%}
              <p class="product__model-info">{{ product.metafields.custom.model_info }}</p>
            {%- endif -%}

            <div class="product__content-main-text-wrapper">
              <div class="product__accordions">

                <details class="product__acc" id="product-details" open>
                  <summary class="product__acc-summary">
                    <span>Details</span>
                    <span class="product__acc-icon" aria-hidden="true"></span>
                  </summary>
                  <div class="product__acc-body">
                    {%- if product.description != blank -%}
                      <div class="product__acc-rich">{{ product.description }}</div>
                    {%- else -%}
                      <p>Crafted from premium Italian fabrics, this piece balances a clean silhouette with thoughtful tailoring. Designed to be worn season after season.</p>
                    {%- endif -%}
                    <ul class="product__acc-list">
                      {%- if product.type != blank -%}<li><span>Type</span><span>{{ product.type }}</span></li>{%- endif -%}
                      {%- if product.vendor != blank -%}<li><span>Brand</span><span>{{ product.vendor }}</span></li>{%- endif -%}
                      {%- if product.metafields.custom.season != blank -%}<li><span>Season</span><span>{{ product.metafields.custom.season }}</span></li>{%- else -%}<li><span>Season</span><span>SS26</span></li>{%- endif -%}
                      <li><span>Composition</span><span>72% Viscose · 28% Silk</span></li>
                      <li><span>Lining</span><span>100% Cupro</span></li>
                      <li><span>Fit</span><span>Regular, true to size</span></li>
                    </ul>
                  </div>
                </details>

                <details class="product__acc">
                  <summary class="product__acc-summary">
                    <span>Size Guide</span>
                    <span class="product__acc-icon" aria-hidden="true"></span>
                  </summary>
                  <div class="product__acc-body">
                    <p>Measurements are shown in centimetres. If you're between sizes we recommend sizing up for a relaxed fit.</p>
                    <div class="product__acc-table-wrap">
                      <table class="product__acc-table">
                        <thead>
                          <tr><th>Size</th><th>Bust</th><th>Waist</th><th>Hips</th></tr>
                        </thead>
                        <tbody>
                          <tr><td>XS</td><td>82</td><td>62</td><td>88</td></tr>
                          <tr><td>S</td><td>86</td><td>66</td><td>92</td></tr>
                          <tr><td>M</td><td>90</td><td>70</td><td>96</td></tr>
                          <tr><td>L</td><td>94</td><td>74</td><td>100</td></tr>
                          <tr><td>XL</td><td>98</td><td>78</td><td>104</td></tr>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </details>

                <details class="product__acc">
                  <summary class="product__acc-summary">
                    <span>Shipping &amp; Returns</span>
                    <span class="product__acc-icon" aria-hidden="true"></span>
                  </summary>
                  <div class="product__acc-body">
                    <ul class="product__acc-bullets">
                      <li><strong>Standard shipping</strong> — 3–5 business days, free over €150.</li>
                      <li><strong>Express shipping</strong> — 1–2 business days, €12.</li>
                      <li><strong>International</strong> — 5–10 business days, calculated at checkout.</li>
                      <li><strong>Free returns</strong> within 14 days of delivery.</li>
                      <li>Items must be unworn and in their original packaging.</li>
                    </ul>
                  </div>
                </details>

                <details class="product__acc">
                  <summary class="product__acc-summary">
                    <span>Payment</span>
                    <span class="product__acc-icon" aria-hidden="true"></span>
                  </summary>
                  <div class="product__acc-body">
                    <p>Pay securely with all major credit cards, Apple Pay, Google Pay, PayPal, and Klarna (3 interest-free installments).</p>
                    <p>All transactions are encrypted end-to-end. We never store your card details.</p>
                    <div class="product__acc-badges">
                      <span>VISA</span><span>Mastercard</span><span>Amex</span><span>Apple Pay</span><span>Google Pay</span><span>PayPal</span><span>Klarna</span>
                    </div>
                  </div>
                </details>

                <details class="product__acc">
                  <summary class="product__acc-summary">
                    <span>Made</span>
                    <span class="product__acc-icon" aria-hidden="true"></span>
                  </summary>
                  <div class="product__acc-body">
                    <p>
                      Designed in Milan and handcrafted in a small family-run atelier in the Veneto region of Italy.
                      Every piece passes through the hands of at least five artisans before it reaches you.
                    </p>
                    <p>
                      We work exclusively with GOTS-certified fabrics and dye houses, and every garment ships in
                      FSC-certified packaging.
                    </p>
                  </div>
                </details>

                <details class="product__acc">
                  <summary class="product__acc-summary">
                    <span>Care Instructions</span>
                    <span class="product__acc-icon" aria-hidden="true"></span>
                  </summary>
                  <div class="product__acc-body">
                    <ul class="product__acc-bullets">
                      <li>Dry clean only.</li>
                      <li>Do not bleach.</li>
                      <li>Iron at low temperature, inside out.</li>
                      <li>Store on a padded hanger away from direct sunlight.</li>
                    </ul>
                  </div>
                </details>

              </div>
            </div>

          </div>
        </div>

      </div>
    </div>
  </div>

  {%- comment -%} ── You might like ── {%- endcomment -%}
  {%- assign rec_collection = product.collections.first -%}
  {%- if rec_collection == blank -%}
    {%- assign type_handle = product.type | handleize -%}
    {%- assign rec_collection = collections[type_handle] -%}
  {%- endif -%}
  {%- if rec_collection == blank -%}{%- assign rec_collection = collections.all -%}{%- endif -%}

  {%- assign rec_count = 0 -%}
  <div class="product__recs">
    <div class="product__recs-header">
      <h2 class="product__recs-title">You might like</h2>
      <a href="{{ rec_collection.url | default: '/collections/all' }}" class="product__recs-all">View all</a>
    </div>

    <div class="product__recs-grid">
      {%- for p in rec_collection.products -%}
        {%- if p.handle != product.handle and rec_count < 8 -%}
          {%- assign rec_count = rec_count | plus: 1 -%}
          <a href="{{ p.url }}" class="product__rec-card">
            <div class="product__rec-img-wrap">
              {%- if p.featured_image != blank -%}
                <img
                  src="{{ p.featured_image | image_url: width: 600, height: 800, crop: 'center' }}"
                  alt="{{ p.featured_image.alt | escape }}"
                  loading="lazy"
                  class="product__rec-img"
                  width="600"
                  height="800"
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'product__rec-img' }}
              {%- endif -%}
            </div>
            <div class="product__rec-info">
              {%- if p.vendor != blank -%}
                <span class="product__rec-vendor">{{ p.vendor }}</span>
              {%- endif -%}
              <span class="product__rec-name">{{ p.title }}</span>
              <span class="product__rec-price">
                {%- if p.compare_at_price > p.price -%}
                  <s class="product__rec-price-compare">{{ p.compare_at_price | money_without_trailing_zeros }}</s>
                {%- endif -%}
                {{ p.price | money_without_trailing_zeros }}
              </span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .product {
    width: 100%;
    font-family: 'Helvetica Neue', -apple-system, BlinkMacSystemFont, sans-serif;
    color: rgb(0, 0, 0);
    background: rgb(255, 255, 255);
  }

  .product__content-wrapper {
    display: flex;
    flex-direction: row;
    width: 100%;
    align-items: flex-start;
  }

  /* ── LEFT: gallery ── */
  .product__content-main-image {
    display: flex;
    flex-direction: row;
    width: 50%;
    position: relative;
  }

  .product__content-progress-bars {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 1px;
    position: sticky;
    top: 50%;
    align-self: flex-start;
    margin: 0 20px 0 0;
    padding-left: 12px;
    z-index: 2;
  }

  .product__content-progress-bar {
    width: 1px;
    height: 28px;
    background: rgba(0, 0, 0, 0.2);
    transition: background 0.2s ease;
  }

  .product__content-progress-bar--active {
    background: rgb(0, 0, 0);
  }

  .product__content-images-container {
    display: flex;
    flex-direction: column;
    gap: 2px;
    width: 100%;
  }

  .product__content-image-item {
    display: block;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #f0f0f0;
  }

  .product__content-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product__placeholder {
    width: 100%;
    height: 100%;
  }

  /* ── RIGHT: info (sticky) ── */
  .product__content-main-text {
    display: flex;
    flex-direction: column;
    width: 50%;
    position: sticky;
    top: 28px;
    align-self: flex-start;
    padding: 28px 40px 28px 60px;
  }

  .product__info-container {
    position: relative;
    max-width: 500px;
    width: 100%;
  }

  /* Wishlist */
  .product__wishlist-button {
    position: absolute;
    top: -10px;
    right: -10px;
    width: 34px;
    padding: 10px;
    background: transparent;
    border: none;
    cursor: pointer;
    color: rgb(0, 0, 0);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Details block */
  .product__details {
    margin-bottom: 28px;
  }

  .product__breadcrumbs {
    font-size: 10px;
    font-weight: 500;
    color: rgb(146, 146, 146);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 22.5px;
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .product__back-link {
    color: inherit;
    text-decoration: none;
  }

  .product__back-link:hover { text-decoration: underline; }

  .product__breadcrumb-sep {
    color: rgb(146, 146, 146);
  }

  .product__title {
    font-size: 13px;
    font-weight: 400;
    font-family: inherit;
    color: rgb(0, 0, 0);
    text-transform: none;
    letter-spacing: -0.1px;
    line-height: 20.8px;
    margin: 0 0 10px;
  }

  .product__vendor {
    display: block;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.3px;
    margin-bottom: 2px;
  }

  .product__description {
    font-size: 13px;
    font-weight: 500;
    color: rgb(0, 0, 0);
    line-height: 17.29px;
    margin-bottom: 22.5px;
  }

  .product__price-container {
    margin-bottom: 22.5px;
  }

  .product__price {
    display: inline-block;
    font-size: 13px;
    font-weight: 400;
    color: rgb(0, 0, 0);
    margin: 0;
  }

  .product__omnibus {
    display: flex;
    font-size: 12px;
    font-weight: 500;
    color: rgb(112, 112, 112);
    margin: 10px 0 0;
  }

  .product__klarna {
    font-size: 12px;
    font-weight: 500;
    color: rgb(0, 0, 0);
    margin: 6px 0 0;
  }

  .product__klarna-logo {
    font-weight: 700;
    color: #ffa8cd;
  }

  /* Colors */
  .product__colors {
    margin-bottom: 28px;
  }

  .product__colors-title {
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    margin: 0 0 12px;
    letter-spacing: 0.05em;
  }

  .product__colors-list {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .product__color-item {
    display: block;
    width: 60px;
    height: 80px;
    cursor: pointer;
    overflow: hidden;
    background: #f5f5f5;
  }

  .product__color-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product__color-item--active {
    outline: 1px solid rgb(0, 0, 0);
    outline-offset: 2px;
  }

  /* Size */
  .product__form {
    margin: 0;
  }

  .product__size-title {
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    display: block;
    margin: 0 0 8px;
    letter-spacing: 0.05em;
  }

  .product__sizes {
    display: grid;
    grid-template-columns: repeat(auto-fill, 72px);
    margin: -1px 0 22.5px -1px;
  }

  .product__size-option {
    width: 72px;
    height: 37px;
    border: 1px solid rgb(224, 224, 224);
    margin: -1px 0 0 -1px;
    font-size: 13px;
    font-weight: 500;
    color: rgb(0, 0, 0);
    text-align: center;
    padding: 10px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    font-family: inherit;
    border-radius: 0;
    transition: border-color 0.15s;
    position: relative;
  }

  .product__size-option:hover:not(.disabled) {
    border-color: rgb(0, 0, 0);
  }

  .product__size-option.disabled {
    color: rgb(146, 146, 146);
    cursor: not-allowed;
    background-image: linear-gradient(
      to top right,
      transparent calc(50% - 0.5px),
      rgb(224, 224, 224) calc(50% - 0.5px),
      rgb(224, 224, 224) calc(50% + 0.5px),
      transparent calc(50% + 0.5px)
    );
  }

  .product__size-option.selected {
    border-color: rgb(0, 0, 0);
  }

  /* Add to cart */
  .product__button {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 37px;
    background: rgb(0, 0, 0);
    color: rgb(255, 255, 255);
    border: 1px solid rgb(0, 0, 0);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    padding: 8px 12px 5px;
    margin-bottom: 22.5px;
    cursor: pointer;
    border-radius: 0;
    letter-spacing: 0.05em;
    font-family: inherit;
    transition: opacity 0.2s;
  }

  .product__button:hover { opacity: 0.85; }

  .product__button:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .product__button-price {
    color: inherit;
  }

  /* Delivery */
  .product__delivery-info {
    margin-bottom: 13px;
  }

  .product__delivery-info p {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    width: 100%;
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    color: rgb(0, 0, 0);
    letter-spacing: 0.05em;
    margin: 0;
  }

  /* Made in badge */
  .product-card__label--made-in {
    display: inline-block;
    font-size: 13px;
    font-weight: 500;
    color: rgb(0, 0, 0);
    border: 1px solid rgb(0, 0, 0);
    padding: 4px 6px 2px;
    background: transparent;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .product__model-info {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: rgb(0, 0, 0);
    margin: 13px 0 0;
  }

  /* Info links */
  .product__content-main-text-wrapper {
    margin-top: 120px;
  }

  .product__info-buttons {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .product__info-button {
    display: block;
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    color: rgb(0, 0, 0);
    padding: 4px 4px 3px;
    cursor: pointer;
    text-decoration: none;
    letter-spacing: 0.05em;
    border-top: 1px solid rgb(224, 224, 224);
  }

  .product__info-button:hover {
    text-decoration: underline;
  }

  .product__info-buttons > :last-child {
    border-bottom: 1px solid rgb(224, 224, 224);
  }

  .product__characteristics {
    margin-top: 22.5px;
    font-size: 13px;
    font-weight: 500;
  }

  .product__characteristics ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .desktop-only {
    display: flex;
  }

  /* ── Accordions ── */
  .product__accordions {
    display: flex;
    flex-direction: column;
    border-top: 1px solid rgb(224, 224, 224);
  }

  .product__acc {
    border-bottom: 1px solid rgb(224, 224, 224);
  }

  .product__acc-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 0;
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    list-style: none;
  }

  .product__acc-summary::-webkit-details-marker { display: none; }

  .product__acc-icon {
    width: 12px;
    height: 12px;
    position: relative;
    flex-shrink: 0;
  }

  .product__acc-icon::before,
  .product__acc-icon::after {
    content: '';
    position: absolute;
    background: currentColor;
    transition: transform 0.25s ease;
  }

  .product__acc-icon::before {
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    transform: translateY(-50%);
  }

  .product__acc-icon::after {
    left: 50%;
    top: 0;
    bottom: 0;
    width: 1px;
    transform: translateX(-50%);
  }

  .product__acc[open] .product__acc-icon::after {
    transform: translateX(-50%) scaleY(0);
  }

  .product__acc-body {
    padding: 4px 0 20px;
    font-size: 13px;
    line-height: 1.6;
    color: rgb(60, 60, 60);
  }

  .product__acc-body p { margin: 0 0 10px; }
  .product__acc-body p:last-child { margin-bottom: 0; }

  .product__acc-rich {
    margin-bottom: 12px;
  }

  .product__acc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .product__acc-list li {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    border-bottom: 1px dashed rgb(235, 235, 235);
    padding-bottom: 6px;
  }

  .product__acc-list li:last-child { border-bottom: none; }

  .product__acc-list li > span:first-child {
    color: rgb(146, 146, 146);
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 0.06em;
  }

  .product__acc-bullets {
    list-style: disc;
    padding-left: 18px;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .product__acc-table-wrap {
    margin-top: 12px;
    overflow-x: auto;
  }

  .product__acc-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
  }

  .product__acc-table th,
  .product__acc-table td {
    padding: 8px 6px;
    border-bottom: 1px solid rgb(235, 235, 235);
    text-align: left;
  }

  .product__acc-table th {
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 11px;
    color: rgb(90, 90, 90);
    font-weight: 500;
  }

  .product__acc-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 10px;
  }

  .product__acc-badges span {
    border: 1px solid rgb(224, 224, 224);
    padding: 4px 8px;
    font-size: 10px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgb(40, 40, 40);
  }

  /* ── You might like ── */
  .product__recs {
    padding: 64px var(--page-margin) 72px;
    border-top: 1px solid rgb(235, 235, 235);
    margin-top: 48px;
  }

  .product__recs-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 24px;
  }

  .product__recs-title {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0;
  }

  .product__recs-all {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-foreground);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .product__recs-all:hover { opacity: 1; }

  .product__recs-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px 2px;
  }

  .product__rec-card {
    text-decoration: none;
    color: var(--color-foreground);
    display: flex;
    flex-direction: column;
  }

  .product__rec-img-wrap {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #f0f0f0;
  }

  .product__rec-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .product__rec-card:hover .product__rec-img {
    transform: scale(1.04);
  }

  .product__rec-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 12px 12px 20px;
  }

  .product__rec-vendor {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .product__rec-name {
    font-size: 13px;
  }

  .product__rec-price {
    font-size: 13px;
    font-weight: 600;
    margin-top: 4px;
  }

  .product__rec-price-compare {
    opacity: 0.5;
    font-weight: 400;
    margin-right: 8px;
  }

  @media (max-width: 1024px) {
    .product__recs-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .product__recs {
      padding: 40px 0 48px;
    }
    .product__recs-header {
      padding: 0 var(--page-margin);
    }
    .product__recs-grid {
      display: flex;
      overflow-x: auto;
      gap: 2px;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      padding: 0 var(--page-margin);
    }
    .product__recs-grid::-webkit-scrollbar { display: none; }
    .product__rec-card {
      flex: 0 0 65%;
      scroll-snap-align: start;
    }
  }

  /* ── Mobile gallery dots (visible only on mobile) ── */
  .product__gallery-dots {
    display: none;
  }

  @media (max-width: 900px) {
    .product__content-wrapper {
      flex-direction: column;
    }

    .product__content-main-image,
    .product__content-main-text {
      width: 100%;
      position: static;
    }

    .product__content-main-text {
      padding: 24px var(--page-margin);
    }

    .product__content-progress-bars {
      display: none;
    }

    .desktop-only {
      display: none;
    }

    .product__content-main-text-wrapper {
      margin-top: 32px;
    }

    /* Mobile horizontal image carousel */
    .product__content-main-image {
      flex-direction: column;
      gap: 10px;
    }

    .product__content-images-container {
      display: flex;
      flex-direction: row;
      gap: 0;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }

    .product__content-images-container::-webkit-scrollbar {
      display: none;
    }

    .product__content-image-item {
      flex: 0 0 100%;
      width: 100%;
      scroll-snap-align: start;
      aspect-ratio: 3 / 4;
    }

    .product__gallery-dots {
      display: flex;
      justify-content: center;
      gap: 6px;
      padding: 8px 0 4px;
    }

    .product__gallery-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: rgba(0, 0, 0, 0.2);
      transition: background 0.2s ease, transform 0.2s ease;
    }

    .product__gallery-dot.is-active {
      background: #000;
      transform: scale(1.3);
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var section = document.querySelector('.product');
    if (!section) return;

    /* ── Size selection ── */
    var sizeBtns = section.querySelectorAll('.product__size-option');
    var variantSelect = section.querySelector('.product__variant-select');
    var hiddenVariantInput = section.querySelector('[data-variant-id]');
    var addBtn = section.querySelector('.product__button');
    var priceEl = section.querySelector('.product__button-price');

    var selectedOptions = [];
    sizeBtns.forEach(function (b) {
      if (b.classList.contains('selected')) {
        selectedOptions[parseInt(b.dataset.optionIndex, 10)] = b.dataset.optionValue;
      }
    });

    function syncVariant() {
      if (!variantSelect) return;
      var combo = selectedOptions.join(' / ');
      var options = variantSelect.querySelectorAll('option');
      for (var i = 0; i < options.length; i++) {
        if (options[i].dataset.options === combo) {
          variantSelect.value = options[i].value;
          if (hiddenVariantInput) hiddenVariantInput.value = options[i].value;
          if (addBtn) addBtn.disabled = options[i].disabled;
          break;
        }
      }
    }

    sizeBtns.forEach(function (btn) {
      if (btn.classList.contains('disabled')) return;
      btn.addEventListener('click', function () {
        var index = parseInt(btn.dataset.optionIndex, 10);
        var value = btn.dataset.optionValue;
        selectedOptions[index] = value;
        section.querySelectorAll('[data-option-index="' + index + '"]').forEach(function (b) {
          b.classList.remove('selected');
        });
        btn.classList.add('selected');
        syncVariant();
      });
    });

    /* ── Scroll progress indicator (desktop vertical + mobile dots) ── */
    var bars = section.querySelectorAll('[data-progress-bar]');
    var dots = section.querySelectorAll('[data-dot]');
    var items = section.querySelectorAll('[data-image-index]');
    if (items.length && 'IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            var idx = entry.target.getAttribute('data-image-index');
            bars.forEach(function (bar) {
              bar.classList.toggle(
                'product__content-progress-bar--active',
                bar.getAttribute('data-progress-bar') === idx
              );
            });
            dots.forEach(function (dot) {
              dot.classList.toggle('is-active', dot.getAttribute('data-dot') === idx);
            });
          }
        });
      }, { threshold: 0.5 });
      items.forEach(function (it) { observer.observe(it); });
    }

    /* ── Expected delivery (today + 3..4 business days) ── */
    var delivery = section.querySelector('[data-delivery-window]');
    if (delivery) {
      var months = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
      var start = new Date(); start.setDate(start.getDate() + 3);
      var end = new Date(); end.setDate(end.getDate() + 4);
      delivery.textContent =
        months[start.getMonth()] + ' ' + start.getDate() + ' - ' + end.getDate();
    }

    /* ── Add to cart (AJAX → opens drawer) ── */
    var addToCartBtn = section.querySelector('[data-add-to-cart]');
    if (addToCartBtn) {
      addToCartBtn.addEventListener('click', function (e) {
        e.preventDefault();
        if (addToCartBtn.disabled) return;
        var variantId = hiddenVariantInput ? hiddenVariantInput.value : null;
        if (!variantId) return;
        var label = addToCartBtn.querySelector('.product__button-label');
        var original = label ? label.textContent : '';
        addToCartBtn.disabled = true;
        if (label) label.textContent = 'Adding…';
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
        }).then(function (r) { return r.ok ? r.json() : Promise.reject(r); })
          .then(function () {
            if (label) label.textContent = 'Added ✓';
            document.dispatchEvent(new CustomEvent('cart:updated'));
            setTimeout(function () {
              if (label) label.textContent = original;
              addToCartBtn.disabled = false;
            }, 1200);
          })
          .catch(function () {
            if (label) label.textContent = 'Try again';
            setTimeout(function () {
              if (label) label.textContent = original;
              addToCartBtn.disabled = false;
            }, 1500);
          });
      });
    }

    /* ── Wishlist (localStorage) ── */
    var wishBtn = section.querySelector('[data-wishlist]');
    if (wishBtn) {
      wishBtn.addEventListener('click', function () {
        try {
          var key = 'leon_wishlist';
          var list = JSON.parse(localStorage.getItem(key) || '[]');
          var handle = window.location.pathname.split('/').pop();
          if (list.indexOf(handle) === -1) list.push(handle);
          else list = list.filter(function (h) { return h !== handle; });
          localStorage.setItem(key, JSON.stringify(list));
          wishBtn.style.color = list.indexOf(handle) !== -1 ? '#000' : '#000';
          wishBtn.querySelector('svg path').setAttribute('fill', list.indexOf(handle) !== -1 ? 'currentColor' : 'none');
        } catch (e) {}
      });
    }
  })();
</script>

