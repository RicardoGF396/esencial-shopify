<div
  class="newsletter full-width"
  style="--newsletter-bg: {{ section.settings.background_color }}"
>
  <div class="newsletter__inner">
    {% if section.settings.heading != blank %}
      <h2 class="newsletter__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.description != blank %}
      <p class="newsletter__description">{{ section.settings.description }}</p>
    {% endif %}

    {% form 'customer' %}
      <div class="newsletter__form">
        <label for="newsletter-email" class="visually-hidden">{{ 'newsletter.email_placeholder' | t }}</label>
        <input
          type="email"
          id="newsletter-email"
          name="contact[email]"
          placeholder="{{ 'newsletter.email_placeholder' | t | upcase }}"
          class="newsletter__input"
          required
        >
        <button type="submit" class="newsletter__button">
          {{ 'newsletter.subscribe' | t }}
        </button>
      </div>
      <p class="newsletter__privacy">{{ 'newsletter.privacy_consent' | t }}</p>
    {% endform %}
  </div>
</div>

{% stylesheet %}
  .newsletter {
    background-color: var(--newsletter-bg);
    padding: 64px var(--page-margin);
  }

  .newsletter__inner {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .newsletter__heading {
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .newsletter__description {
    font-size: 14px;
    line-height: 1.6;
    max-width: 400px;
  }

  .newsletter__form {
    display: flex;
    gap: 0;
    width: 100%;
    max-width: 420px;
    margin-top: 8px;
  }

  .newsletter__input {
    flex: 1;
    border: none;
    border-bottom: 1px solid var(--color-foreground);
    background: transparent;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 10px 0;
    outline: none;
    color: var(--color-foreground);
    font-family: inherit;
    border-radius: 0;
  }

  .newsletter__input::placeholder {
    color: var(--color-foreground);
    opacity: 0.5;
  }

  .newsletter__button {
    background-color: var(--color-foreground);
    color: var(--color-background);
    border: 1px solid var(--color-foreground);
    padding: 10px 24px;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    font-family: inherit;
    white-space: nowrap;
    transition: opacity 0.2s;
  }

  .newsletter__button:hover {
    opacity: 0.85;
  }

  .newsletter__privacy {
    font-size: 11px;
    color: #888;
    margin-top: 4px;
  }

  @media (max-width: 768px) {
    .newsletter {
      padding: 48px var(--page-margin);
    }

    .newsletter__form {
      flex-direction: column;
      gap: 12px;
    }

    .newsletter__button {
      width: 100%;
      padding: 12px 24px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Join the community"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:labels.description",
      "default": "Sign up for our newsletter and get 10% off your first order."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#f0f0f0"
    }
  ],
  "presets": [
    {
      "name": "t:general.newsletter"
    }
  ]
}
{% endschema %}
