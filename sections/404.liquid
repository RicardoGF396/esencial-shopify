<div class="not-found">
  <span class="not-found__code">404</span>
  <p class="not-found__message">{{ '404.not_found' | t }}</p>
  <a href="{{ routes.all_products_collection_url }}" class="not-found__link">
    {{ '404.back_to_shopping' | t }}
  </a>
</div>

{% stylesheet %}
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 0;
    gap: 16px;
  }

  .not-found__code {
    font-size: 64px;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1;
  }

  .not-found__message {
    font-size: 13px;
    letter-spacing: 0.05em;
    opacity: 0.6;
  }

  .not-found__link {
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-foreground);
    text-decoration: none;
    border-bottom: 1px solid var(--color-foreground);
    padding-bottom: 2px;
    margin-top: 16px;
    transition: opacity 0.2s;
  }

  .not-found__link:hover {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .not-found {
      padding: 80px 0;
    }

    .not-found__code {
      font-size: 48px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.404",
  "settings": []
}
{% endschema %}
