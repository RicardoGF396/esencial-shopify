{% if cart.item_count == 0 %}
  <div class="cart-empty">
    <h1 class="cart-empty__title">{{ 'cart.title' | t }}</h1>
    <p class="cart-empty__message">{{ 'cart.empty' | t }}</p>
    <a href="{{ routes.all_products_collection_url }}" class="cart-empty__link">
      {{ 'cart.continue_shopping' | t }}
    </a>
  </div>
{% else %}
  <div class="cart">
    <h1 class="cart__title">{{ 'cart.title' | t }}</h1>

    <form action="{{ routes.cart_url }}" method="post" class="cart__form">
      <div class="cart__items">
        {% for item in cart.items %}
          <div class="cart__item">
            <a href="{{ item.url }}" class="cart__item-image-link">
              <div class="cart__item-image-wrapper">
                {% if item.image != blank %}
                  <img
                    src="{{ item.image | image_url: width: 400, height: 530, crop: 'center' }}"
                    alt="{{ item.image.alt | escape }}"
                    loading="lazy"
                    width="400"
                    height="530"
                    class="cart__item-image"
                  >
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'cart__item-image cart__item-placeholder' }}
                {% endif %}
              </div>
            </a>

            <div class="cart__item-details">
              <div class="cart__item-header">
                {% if item.product.vendor != blank %}
                  <span class="cart__item-vendor">{{ item.product.vendor }}</span>
                {% endif %}
                <a href="{{ item.url }}" class="cart__item-title">{{ item.product.title }}</a>
                {% unless item.variant.title == 'Default Title' %}
                  <span class="cart__item-variant">{{ item.variant.title }}</span>
                {% endunless %}
              </div>

              <div class="cart__item-quantity">
                <div class="cart__quantity-controls">
                  <button
                    type="button"
                    class="cart__quantity-btn"
                    data-cart-minus="{{ forloop.index0 }}"
                    aria-label="{{ 'cart.decrease' | t }}"
                  >−</button>
                  <input
                    type="number"
                    name="updates[]"
                    value="{{ item.quantity }}"
                    min="0"
                    class="cart__quantity-input"
                    aria-label="{{ 'cart.quantity' | t }}"
                  >
                  <button
                    type="button"
                    class="cart__quantity-btn"
                    data-cart-plus="{{ forloop.index0 }}"
                    aria-label="{{ 'cart.increase' | t }}"
                  >+</button>
                </div>
              </div>

              <div class="cart__item-bottom">
                <span class="cart__item-price">{{ item.final_line_price | money }}</span>
                <a href="{{ item.url_to_remove }}" class="cart__item-remove">{{ 'cart.remove' | t }}</a>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      <div class="cart__footer">
        <div class="cart__totals">
          <div class="cart__subtotal">
            <span class="cart__subtotal-label">{{ 'cart.subtotal' | t }}</span>
            <span class="cart__subtotal-price">{{ cart.total_price | money }}</span>
          </div>
          <p class="cart__note">{{ 'cart.shipping_note' | t }}</p>
        </div>

        <button type="submit" name="checkout" class="cart__checkout">
          {{ 'cart.checkout' | t }}
        </button>

        <a href="{{ routes.all_products_collection_url }}" class="cart__continue">
          {{ 'cart.continue_shopping' | t }}
        </a>
      </div>
    </form>
  </div>
{% endif %}

{% stylesheet %}
  .cart-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 80px 0;
    text-align: center;
  }

  .cart-empty__title {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .cart-empty__message {
    font-size: 13px;
    opacity: 0.6;
  }

  .cart-empty__link {
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-foreground);
    text-decoration: none;
    border-bottom: 1px solid var(--color-foreground);
    padding-bottom: 2px;
    margin-top: 8px;
  }

  .cart__title {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 32px 0 24px;
  }

  .cart__form {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 48px;
    padding-bottom: 48px;
  }

  .cart__items {
    display: flex;
    flex-direction: column;
    border-top: 1px solid #e5e5e5;
  }

  .cart__item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 24px;
    padding: 24px 0;
    border-bottom: 1px solid #e5e5e5;
  }

  .cart__item-image-link {
    text-decoration: none;
  }

  .cart__item-image-wrapper {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background-color: #f0f0f0;
  }

  .cart__item-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart__item-placeholder {
    width: 100%;
    height: 100%;
  }

  .cart__item-details {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .cart__item-header {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cart__item-vendor {
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .cart__item-title {
    font-size: 13px;
    text-decoration: none;
    color: var(--color-foreground);
    font-weight: 500;
  }

  .cart__item-variant {
    font-size: 12px;
    opacity: 0.6;
  }

  .cart__quantity-controls {
    display: flex;
    align-items: center;
    border: 1px solid #ccc;
    width: fit-content;
  }

  .cart__quantity-btn {
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    font-size: 14px;
    cursor: pointer;
    color: var(--color-foreground);
    font-family: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cart__quantity-input {
    width: 40px;
    height: 36px;
    text-align: center;
    border: none;
    border-left: 1px solid #ccc;
    border-right: 1px solid #ccc;
    font-size: 13px;
    font-family: inherit;
    color: var(--color-foreground);
    background: none;
    -moz-appearance: textfield;
    border-radius: 0;
  }

  .cart__quantity-input::-webkit-inner-spin-button,
  .cart__quantity-input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .cart__item-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .cart__item-price {
    font-size: 13px;
    font-weight: 600;
  }

  .cart__item-remove {
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-foreground);
    opacity: 0.5;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .cart__item-remove:hover {
    opacity: 1;
  }

  .cart__footer {
    position: sticky;
    top: 24px;
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-top: 24px;
  }

  .cart__subtotal {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 12px;
    border-bottom: 1px solid #e5e5e5;
  }

  .cart__subtotal-label {
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .cart__subtotal-price {
    font-size: 16px;
    font-weight: 600;
  }

  .cart__note {
    font-size: 12px;
    opacity: 0.5;
    line-height: 1.5;
  }

  .cart__checkout {
    width: 100%;
    padding: 14px 24px;
    background-color: var(--color-foreground);
    color: var(--color-background);
    border: 1px solid var(--color-foreground);
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    font-family: inherit;
    transition: opacity 0.2s;
  }

  .cart__checkout:hover {
    opacity: 0.85;
  }

  .cart__continue {
    display: block;
    text-align: center;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-foreground);
    opacity: 0.6;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .cart__continue:hover {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .cart__form {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .cart__item {
      grid-template-columns: 100px 1fr;
      gap: 16px;
    }

    .cart__footer {
      position: static;
    }
  }
{% endstylesheet %}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var cart = document.querySelector('.cart__form');
    if (!cart) return;

    cart.querySelectorAll('[data-cart-minus]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var inputs = cart.querySelectorAll('.cart__quantity-input');
        var index = parseInt(btn.dataset.cartMinus);
        var input = inputs[index];
        if (input) {
          var val = parseInt(input.value, 10);
          if (val > 1) input.value = val - 1;
        }
      });
    });

    cart.querySelectorAll('[data-cart-plus]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var inputs = cart.querySelectorAll('.cart__quantity-input');
        var index = parseInt(btn.dataset.cartPlus);
        var input = inputs[index];
        if (input) {
          var val = parseInt(input.value, 10);
          input.value = val + 1;
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
